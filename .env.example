# ============================================================
# BOLTY PLATFORM — UNIFIED ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# For Vercel: add these in Project Settings > Environment Variables
# NEVER commit .env to version control
# ============================================================

# ══════════════════════════════════════════════════════════════
# FRONTEND (Next.js — Vercel)
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ══════════════════════════════════════════════════════════════

# Backend API URL (your NestJS backend URL)
NEXT_PUBLIC_API_URL=https://api.boltynetwork.xyz/api/v1

# WebSocket URL (same as backend, no path)
NEXT_PUBLIC_WS_URL=https://api.boltynetwork.xyz

# GitHub OAuth client ID (public, safe for browser)
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# GitHub OAuth callback URL (must match GitHub app settings)
NEXT_PUBLIC_GITHUB_CALLBACK_URL=https://api.boltynetwork.xyz/api/v1/auth/github/callback

# Platform wallet address for receiving 2.5% fees
NEXT_PUBLIC_PLATFORM_WALLET=your_platform_wallet_address

# ══════════════════════════════════════════════════════════════
# BACKEND (NestJS — separate hosting: Railway, Render, VPS, etc.)
# These are server-side only. Do NOT add to Vercel.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://boltynetwork.xyz

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CSRF ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CSRF_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

# ── Session ──────────────────────────────────────────────────
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://api.boltynetwork.xyz/api/v1/auth/github/callback

# ── Anthropic Claude AI ──────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Email ────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Bolty <noreply@boltynetwork.xyz>

# ── Blockchain ───────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETH_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
BOLTY_TOKEN_ADDRESS=your_bolty_token_contract_address
BOLTY_TOKEN_NETWORK=solana
PLATFORM_WALLET=your_platform_wallet_address

# ── DEX/Price API ────────────────────────────────────────────
PRICE_API_URL=https://price.jup.ag/v6/price
PRICE_API_KEY=

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=10

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://boltynetwork.xyz

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=warn
