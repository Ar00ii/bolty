# ============================================================
# BOLTY PLATFORM - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://bolty:boltypassword@localhost:5432/boltydb

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_DO_NOT_USE_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CSRF ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CSRF_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

# ── Session ──────────────────────────────────────────────────
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Blockchain ───────────────────────────────────────────────
# Solana RPC (for Phantom)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Ethereum RPC (for MetaMask)
ETH_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id

# Bolty token contract address
BOLTY_TOKEN_ADDRESS=your_bolty_token_contract_address
BOLTY_TOKEN_NETWORK=solana

# DEX/Price API (use Jupiter, Raydium, or DexScreener)
PRICE_API_URL=https://price.jup.ag/v6/price
PRICE_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=10

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Docker (used in docker-compose) ──────────────────────────
POSTGRES_USER=bolty
POSTGRES_PASSWORD=boltypassword
POSTGRES_DB=boltydb
