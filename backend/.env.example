# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bolty

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-at-least-32-characters-long
JWT_EXPIRES_IN=15m
SESSION_SECRET=another-secret-at-least-32-characters

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3001

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@bolty.network

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=

# ── Ethereum / Blockchain ─────────────────────────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ESCROW_CONTRACT=0x0000000000000000000000000000000000000000
BOLTY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
BOLTY_TOKEN_CONTRACT=0x0000000000000000000000000000000000000000
PAYMENT_WALLET=0x0000000000000000000000000000000000000000
PLATFORM_WALLET=0x0000000000000000000000000000000000000000
PRICE_API_URL=https://api.coingecko.com/api/v3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Docker (only needed for docker-compose) ───────────────────────────────────
POSTGRES_USER=bolty
POSTGRES_PASSWORD=bolty
POSTGRES_DB=bolty
