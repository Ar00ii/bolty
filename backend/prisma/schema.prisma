// Bolty Platform - Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Identity
  username      String?   @unique
  avatarUrl     String?
  bio           String?   @db.Text

  // Email / Password auth
  email            String?   @unique
  passwordHash     String?
  twoFactorEnabled Boolean   @default(false)

  // GitHub OAuth
  githubId      String?   @unique
  githubLogin   String?
  githubToken   String?   // encrypted

  // Wallet addresses
  walletAddress String?   @unique  // Ethereum (MetaMask)
  solanaAddress String?   @unique  // Solana (Phantom)
  walletNonce   String?            // current nonce for wallet auth
  nonceExpiry   DateTime?          // nonce expiration

  // Sessions
  refreshToken  String?
  lastLoginAt   DateTime?
  lastLoginIp   String?

  // Profile
  displayName   String?
  twitterUrl    String?
  linkedinUrl   String?
  websiteUrl    String?
  profileSetup  Boolean   @default(false)

  // Roles & Status
  role          UserRole  @default(USER)
  isBanned      Boolean   @default(false)
  banReason     String?

  // Relations
  messages       ChatMessage[]
  repositories   Repository[]
  votes          Vote[]
  reports        Report[]
  aiSessions     AiSession[]
  auditLogs      AuditLog[]
  sentDMs        DirectMessage[]  @relation("SentDMs")
  receivedDMs    DirectMessage[]  @relation("ReceivedDMs")
  marketListings      MarketListing[]      @relation("MarketSeller")
  purchasesMade       RepoPurchase[]       @relation("Buyer")
  buyerNegotiations   AgentNegotiation[]   @relation("NegotiationBuyer")
  sentFriendRequests     Friendship[]  @relation("FriendSent")
  receivedFriendRequests Friendship[]  @relation("FriendReceived")

  @@map("users")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatMessage {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  content     String    @db.Text  // sanitized
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deleteReason String?

  reports     Report[]

  @@map("chat_messages")
}

// ─── Repositories ────────────────────────────────────────────────────────────

model Repository {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // GitHub data
  githubRepoId  String    @unique
  name          String
  fullName      String
  description   String?   @db.Text
  language      String?
  stars         Int       @default(0)
  forks         Int       @default(0)
  githubUrl     String
  cloneUrl      String
  topics        String[]
  isPrivate     Boolean   @default(false)

  // Platform data
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  featured      Boolean   @default(false)
  downloadCount Int       @default(0)

  // Locked repo / monetization
  isLocked      Boolean   @default(false)
  lockedPriceUsd Float?

  votes          Vote[]
  marketListings MarketListing[]
  purchases      RepoPurchase[]

  @@map("repositories")
}

// ─── Repo Purchases (locked repo payments) ───────────────────────────────────

model RepoPurchase {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())

  txHash       String     @unique          // Ethereum tx hash
  verified     Boolean    @default(false)
  amountWei    String     @default("0")    // stored as string to avoid precision loss

  buyerId      String
  buyer        User       @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([buyerId, repositoryId])
  @@map("repo_purchases")
}

// ─── Votes ───────────────────────────────────────────────────────────────────

model Vote {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  value        VoteValue

  @@unique([userId, repositoryId])
  @@map("votes")
}

enum VoteValue {
  UP
  DOWN
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  reason      String    @db.Text
  status      ReportStatus @default(PENDING)

  reporterId  String
  reporter    User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  messageId   String?
  message     ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@map("reports")
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ─── AI Sessions ─────────────────────────────────────────────────────────────

model AiSession {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages    AiMessage[]

  @@map("ai_sessions")
}

model AiMessage {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  role        AiRole
  content     String    @db.Text
  sessionId   String
  session     AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

enum AiRole {
  USER
  ASSISTANT
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ─── Direct Messages ─────────────────────────────────────────────────────────

model DirectMessage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  content    String   @db.Text
  isRead     Boolean  @default(false)

  senderId   String
  sender     User     @relation("SentDMs", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User     @relation("ReceivedDMs", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, createdAt])
  @@map("direct_messages")
}

// ─── Market ───────────────────────────────────────────────────────────────────

model MarketListing {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  title        String
  description  String        @db.Text
  type         ListingType
  price        Float         @default(0)
  currency     String        @default("SOL")
  tags         String[]
  repositoryId String?
  repository   Repository?   @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  sellerId     String
  seller       User          @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  status       ListingStatus @default(PENDING_REVIEW)
  scanPassed   Boolean       @default(false)
  scanNote     String?
  agentUrl     String?       // URL for AI agents (OpenAI, Claude, custom endpoint)
  fileKey       String?       @unique  // stored filename on disk (UUID, no extension)
  fileName      String?       // original filename shown to users
  fileSize      Int?          // bytes
  fileMimeType  String?       // MIME type
  agentEndpoint String?       // Webhook URL — seller's bot receives negotiation messages here
  negotiations  AgentNegotiation[]

  @@map("market_listings")
}

enum ListingType {
  REPO
  BOT
  SCRIPT
  AI_AGENT
  OTHER
}

enum ListingStatus {
  PENDING_REVIEW
  ACTIVE
  SOLD
  REMOVED
}

// ─── Agent Negotiations ───────────────────────────────────────────────────────

model AgentNegotiation {
  id          String             @id @default(cuid())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  listingId   String
  listing     MarketListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User               @relation("NegotiationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  status      NegotiationStatus  @default(ACTIVE)
  agreedPrice Float?
  messages    NegotiationMessage[]

  @@map("agent_negotiations")
}

model NegotiationMessage {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  negotiationId String
  negotiation   AgentNegotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  fromRole      String           // 'buyer' | 'seller' | 'buyer_agent' | 'seller_agent'
  content       String           @db.Text
  proposedPrice Float?

  @@map("negotiation_messages")
}

enum NegotiationStatus {
  ACTIVE
  AGREED
  REJECTED
  EXPIRED
}

// ─── Price Cache ──────────────────────────────────────────────────────────────

model PriceSnapshot {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  price       Float
  volume24h   Float?
  marketCap   Float?
  change24h   Float?
  source      String

  @@map("price_snapshots")
}

// ─── Friendships ──────────────────────────────────────────────────────────────

model Friendship {
  id         String           @id @default(cuid())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  senderId   String
  sender     User             @relation("FriendSent",     fields: [senderId],   references: [id], onDelete: Cascade)

  receiverId String
  receiver   User             @relation("FriendReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  status     FriendshipStatus @default(PENDING)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}
