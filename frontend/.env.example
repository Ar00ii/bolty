# ── Backend connection ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── GitHub OAuth (must match backend GITHUB_CLIENT_ID) ───────────────────────
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── Base Network (Ethereum L2) — only supported chain ───────────────────────
# Mainnet chainId: 8453 · RPC: https://mainnet.base.org · Explorer: https://basescan.org
NEXT_PUBLIC_ETH_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_ESCROW_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PLATFORM_WALLET=0x0000000000000000000000000000000000000000
# BOLTY ERC-20 on Base (18 decimals). Lower 3% platform fee vs 7% for ETH.
NEXT_PUBLIC_BOLTY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# ── WalletConnect ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
